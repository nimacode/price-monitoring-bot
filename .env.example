# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_USER=admin
MONGO_PASSWORD=change_me_strong_password
MONGO_DB=price_monitor
DB_NAME=price_monitor

# Telegram Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
CHANNEL_ID=your_channel_id_here
ADMIN_ID=your_admin_user_id_here

# Logging
LOG_FILE=logs/bot.log
DEBUG=false

# Scraper Configuration (for 100+ sources)
SCRAPER_CONCURRENCY=20
SCRAPER_TIMEOUT=30s
SCRAPER_RETRY_COUNT=3
SCRAPER_RETRY_WAIT=2s

# Scheduler Configuration
SCHEDULER_FETCH_CRON=0 */10 * * * *
SCHEDULER_POST_CRON=0 */30 * * * *

# Alert Thresholds (decimal, e.g., 0.01 = 1%)
ALERT_THRESHOLD_GOLD=0.01
ALERT_THRESHOLD_CRYPTO=0.03
ALERT_THRESHOLD_FIAT=0.01
